.env
__pycache__/
*.pyc
*.pyo
.DS_Store
*.egg-info/
.venv/
.claude/settings.local.json
.superpowers/

# Local ad-hoc / test runs — viewable in the run viewer, never published
outputs/*/runs/local_*/

# The `latest` symlinks are machine-local pointers that churn on every run and
# dangle for anyone who prunes runs — regenerated by the pipeline, not tracked.
outputs/*/latest

# Per-run embedding caches (evals/diversity.py) — megabytes of float32 vectors,
# regenerated for cents; the diversity_report.json next to them stays tracked.
# Bare filename so it matches wherever --input puts the audit/ dir (run dirs
# under outputs/, but also next to a bare --input corpus.jsonl anywhere).
embeddings_cache.npz

# viewer session state
outputs/gui_runs/
