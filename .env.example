# Copy this file to .env and fill in your key:
#   cp .env.example .env
# Ask Oliver for an API key (required for backend: api, the default)
ANTHROPIC_API_KEY=
# Optional — only for backend: claude_code (bills your Claude Max subscription).
# Generate with: claude setup-token
# Not needed if you're already logged into Claude Code on this machine.
CLAUDE_CODE_OAUTH_TOKEN=
