# Copy this file to .env and fill in your key:
#   cp .env.example .env
# Ask Oliver for an API key
ANTHROPIC_API_KEY=

# Optional — only needed to run JUDGE panels with Gemini models (evals/):
# Option A — Gemini API key (aistudio.google.com)
GEMINI_API_KEY=
# Option B — Vertex AI project (then: gcloud auth application-default login)
VERTEX_PROJECT=
